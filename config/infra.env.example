# ─── Infrastructure Configuration ─────────────────────────────
# 機密性の低い、環境依存のインフラ設定。
# Docker Compose の env_file として読み込まれる。
#
# シークレット (JWT_SECRET, GOOGLE_CLIENT_SECRET 等) はここに書かず、
# Infisical 等の CMS から取得すること。
# ──────────────────────────────────────────────────────────────

# ─── Port Configuration ──────────────────────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

# ─── Database ────────────────────────────────────────────────
DB_DIALECT=postgres
POSTGRES_USER=schedula
POSTGRES_PASSWORD=schedula
POSTGRES_DB=schedula

# ─── Internal Service URLs (Docker network) ──────────────────
# コンテナ間通信用。ホストからのアクセスには上記ポートを使用。
DATABASE_URL=postgresql://schedula:schedula@db:5432/schedula
REDIS_URL=redis://redis:6379
