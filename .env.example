# ═══════════════════════════════════════════════════════════════
# Schedula 環境変数
# ═══════════════════════════════════════════════════════════════
#
# 設定は2層に分離されています:
#
#   1. config/infra.env  — ポート番号、DB接続先等のインフラ設定 (機密性低)
#      → Docker Compose が env_file で直接読み込み
#      → config/infra.env.example をコピーして編集
#
#   2. .env.secrets      — Infisical bootstrap credentials
#      → `npm run secrets setup` で対話形式で生成
#      → Docker Compose がバックエンドに env_file で渡す
#
# この .env ファイルは、CMS を使わずに直接環境変数で動かす場合や、
# CMS で管理しないオーバーライド用に使用します。
# ═══════════════════════════════════════════════════════════════

# ─── Frontend URL (Google OAuth callback redirect先) ─────────
# 本番ドメイン例: https://schedula.example.com
# ローカル開発例:  http://localhost:8080
# FRONTEND_URL=https://schedula.example.com

# ─── Google OAuth (optional) ─────────────────────────────────
# Google認証は任意です。設定しない場合はパスワード認証 + 手動予定管理のみ。
# → Infisical 利用時はこれらを Infisical 側で管理推奨
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://schedula.example.com/api/auth/google/callback

# ─── JWT Secret ──────────────────────────────────────────────
# → Infisical 利用時は Infisical 側で管理推奨
# JWT_SECRET=change-me-in-production

# ─── シークレットプロバイダー選択 (optional) ──────────────────
# "infisical" または "ssm" (未設定時は自動検出)
# SECRETS_PROVIDER=infisical
