# ─── External port configuration ─────────────────────────────
# Override these to change the host-side ports exposed by Docker.
FRONTEND_PORT=8080
BACKEND_PORT=3000
DB_PORT=5432

# ─── Frontend URL (Google OAuth callback redirect先) ─────────
# FRONTEND_URL=http://localhost:5173

# ─── Google OAuth (optional) ─────────────────────────────────
# Google認証は任意です。設定しない場合はパスワード認証 + 手動予定管理のみ。
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
