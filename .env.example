# ─── External port configuration ─────────────────────────────
# Override these to change the host-side ports exposed by Docker.
FRONTEND_PORT=8080
BACKEND_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

# ─── Frontend URL (Google OAuth callback redirect先) ─────────
# 本番ドメイン例: https://schedula.example.com
# ローカル開発例:  http://localhost:8080
# FRONTEND_URL=https://schedula.example.com

# ─── Google OAuth (optional) ─────────────────────────────────
# Google認証は任意です。設定しない場合はパスワード認証 + 手動予定管理のみ。
# Google Cloud Console の「承認済みリダイレクト URI」にも同じ値を設定してください。
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://schedula.example.com/api/auth/google/callback

# ─── Redis (セッション永続化, optional) ──────────────────────
# Redisが利用可能な場合はセッションをRedisに保存。未設定ならDBフォールバック。
# REDIS_URL=redis://localhost:6379

# ─── シークレット管理 (optional) ─────────────────────────────
# 外部シークレットプロバイダーを有効にすると、環境変数をプロバイダーから取得します。
# 未設定の場合はこれまで通り process.env を使用 (フォールバックモード)。
#
# プロバイダー選択: "ssm" または "infisical" (未設定時は自動検出)
# SECRETS_PROVIDER=ssm

# ─── AWS SSM Parameter Store (推奨) ──────────────────────────
# AWS のマネージドサービスでシークレットを管理。EC2/ECS/Lambda では
# IAM ロールで自動認証されるため、アクセスキーの設定は不要です。
#
# パスプレフィックス (必須: この配下のパラメータを全て取得)
# 例: /schedula/prod/ → /schedula/prod/JWT_SECRET, /schedula/prod/DATABASE_URL 等
# SSM_PATH_PREFIX=/schedula/prod/
#
# AWS リージョン (デフォルト: ap-northeast-1)
# AWS_REGION=ap-northeast-1
#
# --- 認証 (EC2/ECS/Lambda 以外の場合のみ必要) ---
# IAM ロールが使えない環境ではアクセスキーを設定してください。
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Infisical (代替プロバイダー) ────────────────────────────
# オープンソースのシークレット管理プラットフォーム。
#
# プロジェクトID (必須: Infisical ダッシュボードの Settings → General)
# INFISICAL_PROJECT_ID=
#
# 環境名 (デフォルト: dev)
# INFISICAL_ENVIRONMENT=dev
#
# --- 認証方式 (いずれか1つを選択) ---
#
# Universal Auth (推奨: Machine Identity)
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
#
# または Service Token (簡易)
# INFISICAL_TOKEN=
#
# Infisical インスタンス URL (セルフホスト時のみ変更)
# INFISICAL_SITE_URL=https://app.infisical.com
